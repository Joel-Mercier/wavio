{
	"name": "wavio-monorepo",
	"private": true,
	"license": "MIT",
	"packageManager": "bun@1.3.13",
	"workspaces": [
		"apps/*"
	],
	"scripts": {
		"mobile:start": "bun run --cwd apps/mobile start",
		"mobile:android": "bun run --cwd apps/mobile android",
		"mobile:ios": "bun run --cwd apps/mobile ios",
		"mobile:web": "bun run --cwd apps/mobile web",
		"mobile:test": "bun run --cwd apps/mobile test",
		"mobile:doctor": "bun run --cwd apps/mobile doctor",
		"mobile:lint": "bun run --cwd apps/mobile lint",
		"mobile:lint:fix": "bun run --cwd apps/mobile lint:fix",
		"mobile:typecheck": "bun run --cwd apps/mobile typecheck",
		"mobile:prebuild": "bun run --cwd apps/mobile prebuild",
		"mobile:build:android:development": "bun run --cwd apps/mobile build:android:development",
		"mobile:build:android:preview": "bun run --cwd apps/mobile build:android:preview",
		"mobile:build:android:production": "bun run --cwd apps/mobile build:android:production",
		"mobile:build:android:production-apk": "bun run --cwd apps/mobile build:android:production-apk",
		"mobile:build:android:production-apk-armv7": "bun run --cwd apps/mobile build:android:production-apk-armv7",
		"mobile:submit:android:closed": "bun run --cwd apps/mobile submit:android:closed",
		"mobile:submit:android:production": "bun run --cwd apps/mobile submit:android:production",
		"landing:dev": "bun run --cwd apps/landing dev",
		"landing:build": "bun run --cwd apps/landing build",
		"landing:preview": "bun run --cwd apps/landing preview"
	},
	"patchedDependencies": {
		"expo-audio@57.0.0": "patches/expo-audio@57.0.0.patch",
		"zod@4.4.3": "patches/zod@4.4.3.patch",
		"expo-navigation-bar@57.0.1": "patches/expo-navigation-bar@57.0.1.patch",
		"lucide-react-native@1.23.0": "patches/lucide-react-native@1.23.0.patch"
	},
	"dependencies": {
		"eas-cli": "^20.2.0",
		"jest": "~29.7.0",
		"jest-expo": "~57.0.1"
	}
}
