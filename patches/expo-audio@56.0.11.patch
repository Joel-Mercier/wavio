+  // Queue a next item so ExoPlayer can transition into it gaplessly when the
+  // current item ends. Replaces any previously prepared next item.
+  fun prepareNext(source: MediaSource) {
+    val count = ref.mediaItemCount
+    val current = ref.currentMediaItemIndex
+    if (count > current + 1) {
+      ref.removeMediaItems(current + 1, count)
+    }
+    ref.addMediaSource(source)
+  }
+
+  fun clearPreparedNext() {
+    val count = ref.mediaItemCount
+    val current = ref.currentMediaItemIndex
+    if (count > current + 1) {
+      ref.removeMediaItems(current + 1, count)
+    }
+  }
+
+  fun emitRemotePrevious() {
+    emit(REMOTE_PREVIOUS)
+  }
+
+  fun emitRemoteNext() {
+    emit(REMOTE_NEXT)
+  }
+
+  override fun onMediaItemChanged(mediaItem: MediaItem?, reason: Int) {
+    super.onMediaItemChanged(mediaItem, reason)
+    if (reason == Player.MEDIA_ITEM_TRANSITION_REASON_AUTO) {
+      emit(NEXT_TRACK_STARTED)
+      // Trim the consumed item so the timeline stays at one entry until
+      // JS calls prepareNext() again.
+      val current = ref.currentMediaItemIndex
+      if (current > 0) {
+        ref.removeMediaItems(0, current)
+      }
+    }
