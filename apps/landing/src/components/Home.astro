---
import { Image } from "astro:assets";
import Jellyfin from "../assets/jellyfin.svg";
import Logo from "../assets/logo.svg";
import Navidrome from "../assets/navidrome.svg";
import OpenSubsonic from "../assets/opensubsonic.svg";
import SmartPhone from "../assets/smartphone.svg";
import widgets from "../assets/widgets.png";
import { GITHUB_URL, RELEASES_URL } from "../consts";
import { useImages } from "../i18n/assets";
import { type Lang, useTranslations } from "../i18n/utils";
import Layout from "../layouts/Layout.astro";
import Footer from "./Footer.astro";
import Nav from "./Nav.astro";

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const f = t.features;

const img = useImages(lang);
const showcase = [
	img("home"),
	img("album"),
	img("artist"),
	img("player"),
	img("library"),
	img("search"),
	img("queue"),
	img("smart-playlist"),
	img("offline-1"),
	img("settings"),
	img("login"),
];

let wordIndex = 0;
const wordDelay = () =>
	`animation-delay:${(0.05 + wordIndex++ * 0.1).toFixed(2)}s`;
---

<Layout title={t.meta.homeTitle} description={t.meta.homeDescription} lang={lang}>
	<Nav lang={lang} showLinks />

	<!-- ─────────────  Hero  ───────────── -->
	<section class="relative isolate min-h-[92vh] overflow-hidden pt-15 pb-25">
		<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
			<svg class="wave wave-1 absolute -left-1/2 h-auto w-[200%] opacity-55" viewBox="0 0 1200 200" fill="none" preserveAspectRatio="none">
				<path d="M0 100 Q 150 20, 300 100 T 600 100 T 900 100 T 1200 100" stroke="#10b981" stroke-width="2" fill="none"/>
			</svg>
			<svg class="wave wave-2 absolute -left-1/2 h-auto w-[200%] opacity-35" viewBox="0 0 1200 200" fill="none" preserveAspectRatio="none">
				<path d="M0 100 Q 150 180, 300 100 T 600 100 T 900 100 T 1200 100" stroke="#10b981" stroke-width="2" fill="none"/>
			</svg>
			<svg class="wave wave-3 absolute -left-1/2 h-auto w-[200%] opacity-20" viewBox="0 0 1200 200" fill="none" preserveAspectRatio="none">
				<path d="M0 100 Q 150 40, 300 100 T 600 100 T 900 100 T 1200 100" stroke="#10b981" stroke-width="2" fill="none"/>
			</svg>
			<div
				class="absolute inset-0"
				style="background: radial-gradient(ellipse 70% 50% at 50% 110%, rgba(16,185,129,0.18), transparent 60%)"
			>
			</div>
		</div>

		<div
			class="relative z-10 mx-auto grid max-w-[1280px] grid-cols-1 items-center gap-10 px-8 lg:grid-cols-[1.1fr_0.9fr]"
		>
			<div class="pt-5">
				<div class="mb-7 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.14em] text-accent">
					<span class="h-px w-8 bg-accent"></span> {t.hero.tag}
				</div>
				<h1 class="mb-9 text-[clamp(56px,9vw,132px)] font-extrabold leading-[1.02] tracking-[-0.055em]">
					{
						t.hero.titleLines.map((line) => (
							<span class="block">
								{line.map((word) => (
									<><span class="hero-word inline-block" style={wordDelay()}>{word}</span>{' '}</>
								))}
							</span>
						))
					}
					<span class="block">
						<span class="hero-word inline-block italic text-accent" style={wordDelay()}>{t.hero.titleAccent}</span>
					</span>
				</h1>
				<p class="mb-10 max-w-[520px] text-[clamp(17px,1.4vw,20px)] text-text-2 [animation:rise_1s_cubic-bezier(0.22,1,0.36,1)_0.6s_backwards]">
					{t.hero.lead}
				</p>
				<div class="flex flex-wrap items-center gap-3.5 [animation:rise_1s_cubic-bezier(0.22,1,0.36,1)_0.75s_backwards]">
					<a
						href={RELEASES_URL}
						target="_blank"
						rel="noopener"
						class="relative inline-flex items-center gap-3.5 rounded-[14px] bg-accent py-3.5 pl-[22px] pr-[26px] font-bold text-ink shadow-[0_12px_36px_-8px_rgba(16,185,129,0.35),inset_0_1px_0_rgba(255,255,255,0.2)] transition-all duration-150 hover:-translate-y-0.5 hover:shadow-[0_18px_44px_-8px_rgba(16,185,129,0.35),inset_0_1px_0_rgba(255,255,255,0.2)]"
					>
						<svg class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M12 3v12m0 0l-4-4m4 4l4-4M4 19h16"/>
						</svg>
						<span class="flex flex-col items-start leading-[1.15]">
							<span class="text-[17px] font-extrabold tracking-[-0.01em]">{t.cta.releaseMain}</span>
							<span class="text-[11px] font-semibold tracking-[0.04em] opacity-75">{t.cta.releaseNote}</span>
						</span>
					</a>
					<a
						href={GITHUB_URL}
						target="_blank"
						rel="noopener"
						class="inline-flex items-center gap-2.5 rounded-[14px] border border-border-strong px-[22px] py-3.5 text-sm font-medium text-text transition-colors duration-200 hover:border-accent hover:bg-accent-soft"
					>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2.2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.8-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2.9-.3 2-.4 3-.4s2.1.1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.9 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.3.8 1 .8 2v3c0 .3.2.6.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"/>
						</svg>
						{t.cta.starGithub}
					</a>
				</div>
			</div>

			<div class="relative flex items-center justify-center [perspective:1200px]">
				<div class="chip animate-chip-float absolute left-[-8%] top-[6%] flex size-[88px] items-center justify-center overflow-hidden rounded-xl border border-border-strong bg-white p-4 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.6)] [animation-delay:-1s]">
					<Jellyfin class="size-full" aria-label="Jellyfin" />
				</div>
				<div class="chip animate-chip-float absolute bottom-[22%] left-[-4%] flex size-[70px] items-center justify-center overflow-hidden rounded-xl border border-border-strong bg-white p-3 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.6)] [animation-delay:-3s]">
					<Navidrome class="size-full" aria-label="Navidrome" />
				</div>
				<div class="chip animate-chip-float absolute right-[-10%] top-[14%] flex size-[96px] items-center justify-center overflow-hidden rounded-xl border border-border-strong bg-white p-4 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.6)] [animation-delay:-2s]">
					<OpenSubsonic class="size-full" aria-label="OpenSubsonic" />
				</div>
        <div class="chip animate-chip-float absolute right-[-10%] top-[44%] flex size-[88px] items-center justify-center overflow-hidden rounded-xl border border-border-strong bg-white p-4 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.6)] [animation-delay:-4s]">
					<SmartPhone class="size-full stroke-black" aria-label="SmartPhone" />
				</div>
				<div
					class="phone-float animate-hover relative w-[280px] overflow-hidden rounded-[44px] border border-border-strong bg-black shadow-[0_60px_120px_-20px_rgba(0,0,0,0.8),0_0_0_1px_rgba(255,255,255,0.04)_inset,0_0_80px_-10px_rgba(16,185,129,0.35)] sm:w-[340px]"
				>
					<Image src={img('home')} alt={f.home.title} loading="eager" class="block w-full" />
				</div>
			</div>
		</div>
	</section>

	<!-- ─────────────  Highlights  ───────────── -->
	<section class="py-20">
		<div class="mx-auto max-w-[1280px] px-8">
			<div class="mb-10 text-center text-[11px] font-bold uppercase tracking-[0.32em] text-accent">
				{t.highlightsLabel}
			</div>
			<div class="mx-auto grid max-w-[1080px] grid-cols-1 overflow-hidden rounded-[20px] border border-border sm:grid-cols-2 lg:grid-cols-3">
				{
					t.highlights.map((hl, i) => (
						<div
							class:list={[
								'flex items-center gap-5 p-7',
								i % 3 !== 2 && 'lg:border-r lg:border-border',
								i % 2 !== 1 && 'sm:max-lg:border-r sm:max-lg:border-border',
								i < t.highlights.length - 3 && 'lg:border-b lg:border-border',
								i < t.highlights.length - 2 && 'max-lg:border-b max-lg:border-border',
							]}
						>
							<span class="flex size-11 shrink-0 items-center justify-center rounded-xl border border-accent/30 bg-accent/10 text-accent shadow-[0_0_24px_-4px_rgba(16,185,129,0.35)]">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path d="M5 12l5 5L20 7" />
								</svg>
							</span>
							<span class="text-[17px] font-bold leading-snug tracking-[-0.01em] text-text text-balance">{hl}</span>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<!-- ─────────────  Bento Features  ───────────── -->
	<section id="features" class="relative pb-20 pt-35">
		<div class="mx-auto max-w-[1280px] px-8">
			<div class="mb-20 grid grid-cols-1 items-end gap-x-15 gap-y-6 lg:grid-cols-2">
				<h2 class="text-[clamp(40px,5.5vw,76px)] font-extrabold leading-[1.02] tracking-[-0.04em] text-balance">
					{f.headingPre} <em class="font-extrabold italic text-accent pr-[0.12em]">{f.headingEm}</em> {f.headingPost}
				</h2>
				<p class="self-end text-lg text-text-2 text-pretty">{f.sub}</p>
			</div>

			<div class="grid grid-cols-1 gap-3.5 sm:grid-cols-2 lg:grid-cols-6 lg:auto-rows-[220px]">
				<!-- hero cell -->
				<div class="cell group relative flex flex-col overflow-hidden rounded-[20px] border border-border p-7 transition-all duration-300 hover:-translate-y-0.5 hover:border-accent sm:col-span-2 lg:col-span-4 lg:row-span-2" style="background:radial-gradient(ellipse 60% 100% at 80% 100%, rgba(16,185,129,0.22), transparent 60%), linear-gradient(180deg, #0b0e10, #0e1414)">
					<div class="mb-2.5 text-[11px] font-bold uppercase tracking-[0.14em] text-accent">{f.home.label}</div>
					<h3 class="mb-2.5 max-w-[380px] text-[36px] font-bold leading-[1.15] tracking-[-0.02em]">{f.home.title}</h3>
					<p class="max-w-[360px] text-[14.5px] text-text-2 text-pretty">{f.home.desc}</p>
					<div class="pointer-events-none absolute -bottom-[230px] right-9 hidden w-[240px] lg:block">
						<Image src={img('home')} alt="" class="w-full rounded-t-[18px] shadow-[0_-30px_60px_-10px_rgba(0,0,0,0.5)]" />
					</div>
				</div>

				<!-- equalizer cell -->
				<div class="cell group relative flex flex-col overflow-hidden rounded-[20px] border border-border bg-bg-2 p-7 transition-all duration-300 hover:-translate-y-0.5 hover:border-accent sm:col-span-2 lg:col-span-2">
					<div class="mb-2.5 text-[11px] font-bold uppercase tracking-[0.14em] text-accent">{f.audiophile.label}</div>
					<h3 class="mb-2.5 text-[22px] font-bold leading-[1.15] tracking-[-0.02em]">{f.audiophile.title}</h3>
					<p class="text-[14.5px] text-text-2">{f.audiophile.desc}</p>
					<div class="eq-big mt-auto flex h-20 items-end gap-1.5" aria-hidden="true">
						{Array.from({ length: 12 }).map(() => <i class="block flex-1 rounded-[3px]" />)}
					</div>
				</div>

				<!-- offline image cell -->
				<div class="cell-image group relative flex flex-col overflow-hidden rounded-[20px] border border-border bg-linear-to-r from-transparent to-[#1c1c1e] transition-all duration-300 hover:-translate-y-0.5 hover:border-accent sm:col-span-2 lg:col-span-2 lg:min-h-0 min-h-[300px]">
					<Image src={img('offline-1')} alt={f.offline.title} class="absolute top-1/2 left-1/2 -translate-1/2 size-2/3 object-cover object-top" />
					<div class="absolute inset-0 bg-linear-to-b from-transparent from-30% to-black"></div>
					<div class="relative z-10 mt-auto p-7">
						<div class="mb-2.5 text-[11px] font-bold uppercase tracking-[0.14em] text-accent">{f.offline.label}</div>
						<h3 class="text-[22px] font-bold leading-[1.15] tracking-[-0.02em]">{f.offline.title}</h3>
					</div>
				</div>

				<!-- quote cell -->
				<div class="group relative flex flex-col overflow-hidden rounded-[20px] border border-transparent p-7 text-ink transition-transform duration-300 hover:-translate-y-0.5 sm:col-span-2 lg:col-span-2" style="background:linear-gradient(135deg, #10b981, #0a7f5c)">
					<div class="mb-2.5 text-[11px] font-bold uppercase tracking-[0.14em] text-ink/70">{f.quote.label}</div>
					<h3 class="text-lg font-bold leading-[1.15] tracking-[-0.02em]">{f.quote.title}</h3>
				</div>

				<!-- playlists image -->
				<div class="cell-image group relative flex flex-col overflow-hidden rounded-[20px] border border-border bg-linear-to-r from-transparent to-[#1c1c1e] transition-all duration-300 hover:-translate-y-0.5 hover:border-accent sm:col-span-2 lg:col-span-2 min-h-[300px] lg:min-h-0">
					<Image src={img('smart-playlist')} alt={f.playlists.title} class="absolute top-1/2 left-1/2 -translate-1/2 size-2/3 object-cover object-top" />
					<div class="absolute inset-0 bg-linear-to-b from-transparent from-30% to-black"></div>
					<div class="relative z-10 mt-auto p-7">
						<div class="mb-2.5 text-[11px] font-bold uppercase tracking-[0.14em] text-accent">{f.playlists.label}</div>
						<h3 class="text-[22px] font-bold leading-[1.15] tracking-[-0.02em]">{f.playlists.title}</h3>
					</div>
				</div>

				<!-- android auto image -->
				<div class="cell-image group relative flex flex-col overflow-hidden rounded-[20px] border border-border bg-linear-to-r from-transparent to-[#1c1c1e] transition-all duration-300 hover:-translate-y-0.5 hover:border-accent sm:col-span-2 lg:col-span-2 min-h-[300px] lg:min-h-0">
					<Image src={img('android-auto')} alt={f.auto.title} class="absolute top-1/2 left-1/2 -translate-1/2 size-2/3 object-cover object-center" />
					<div class="absolute inset-0 bg-linear-to-b from-transparent from-30% to-black"></div>
					<div class="relative z-10 mt-auto p-7">
						<div class="mb-2.5 text-[11px] font-bold uppercase tracking-[0.14em] text-accent">{f.auto.label}</div>
						<h3 class="text-[22px] font-bold leading-[1.15] tracking-[-0.02em]">{f.auto.title}</h3>
					</div>
				</div>

				<!-- queue -->
				<div class="cell group relative flex flex-col overflow-hidden rounded-[20px] border border-border bg-bg-2 p-7 transition-all duration-300 hover:-translate-y-0.5 hover:border-accent sm:col-span-2 lg:col-span-2">
					<div class="mb-2.5 text-[11px] font-bold uppercase tracking-[0.14em] text-accent">{f.queue.label}</div>
					<h3 class="mb-2.5 text-[22px] font-bold leading-[1.15] tracking-[-0.02em]">{f.queue.title}</h3>
					<p class="text-[14.5px] text-text-2 text-pretty">{f.queue.desc}</p>
				</div>

				<!-- servers -->
				<div class="cell group relative flex flex-col overflow-hidden rounded-[20px] border border-border bg-bg-2 p-7 transition-all duration-300 hover:-translate-y-0.5 hover:border-accent sm:col-span-2 lg:col-span-2">
					<div class="mb-2.5 text-[11px] font-bold uppercase tracking-[0.14em] text-accent">{f.servers.label}</div>
					<h3 class="mb-2.5 text-[22px] font-bold leading-[1.15] tracking-[-0.02em]">{f.servers.title}</h3>
					<p class="text-[14.5px] text-text-2 text-pretty">{f.servers.desc}</p>
				</div>

				<!-- sleep timer -->
				<div class="cell group relative flex flex-col overflow-hidden rounded-[20px] border border-border bg-bg-2 p-7 transition-all duration-300 hover:-translate-y-0.5 hover:border-accent sm:col-span-2 lg:col-span-2">
					<div class="mb-2.5 text-[11px] font-bold uppercase tracking-[0.14em] text-accent">{f.sleep.label}</div>
					<h3 class="mb-2.5 text-[22px] font-bold leading-[1.15] tracking-[-0.02em]">{f.sleep.title}</h3>
					<p class="text-[14.5px] text-text-2 text-pretty">{f.sleep.desc}</p>
				</div>

        <!-- home screen widgets -->
				<div class="cell group relative flex flex-col justify-end overflow-hidden rounded-[20px] border border-border p-7 transition-all duration-300 hover:-translate-y-0.5 hover:border-accent sm:col-span-2 lg:col-span-6" style="background:radial-gradient(ellipse 60% 120% at 15% 0%, rgba(16,185,129,0.18), transparent 60%), linear-gradient(180deg, #0b0e10, #0e1414)">
          <Image src={widgets} alt={f.widgets.title} class="absolute top-1/2 right-0 hidden -translate-y-1/2 w-1/3 object-cover object-center drop-shadow-[0_0_60px_rgba(16,185,129,0.35)] lg:block" />
          <div class="max-w-[520px]">
						<div class="mb-2.5 text-[11px] font-bold uppercase tracking-[0.14em] text-accent">{f.widgets.label}</div>
						<h3 class="mb-2.5 text-[28px] font-bold leading-[1.15] tracking-[-0.02em]">{f.widgets.title}</h3>
						<p class="text-[14.5px] text-text-2 text-pretty">{f.widgets.desc}</p>
					</div>
				</div>

				<!-- podcasts -->
				<div class="cell group relative flex flex-col overflow-hidden rounded-[20px] border border-border bg-bg-2 p-7 transition-all duration-300 hover:-translate-y-0.5 hover:border-accent sm:col-span-2 lg:col-span-2">
					<div class="mb-2.5 text-[11px] font-bold uppercase tracking-[0.14em] text-accent">{f.podcasts.label}</div>
					<h3 class="mb-2.5 text-[22px] font-bold leading-[1.15] tracking-[-0.02em]">{f.podcasts.title}</h3>
					<p class="text-[14.5px] text-text-2 text-pretty">{f.podcasts.desc}</p>
				</div>

				<!-- internet radio -->
				<div class="cell group relative flex flex-col overflow-hidden rounded-[20px] border border-border bg-bg-2 p-7 transition-all duration-300 hover:-translate-y-0.5 hover:border-accent sm:col-span-2 lg:col-span-2">
					<div class="mb-2.5 text-[11px] font-bold uppercase tracking-[0.14em] text-accent">{f.radio.label}</div>
					<h3 class="mb-2.5 text-[22px] font-bold leading-[1.15] tracking-[-0.02em]">{f.radio.title}</h3>
					<p class="text-[14.5px] text-text-2 text-pretty">{f.radio.desc}</p>
				</div>

				<!-- synced lyrics -->
				<div class="cell group relative flex flex-col overflow-hidden rounded-[20px] border border-border bg-bg-2 p-7 transition-all duration-300 hover:-translate-y-0.5 hover:border-accent sm:col-span-2 lg:col-span-2">
					<div class="mb-2.5 text-[11px] font-bold uppercase tracking-[0.14em] text-accent">{f.lyrics.label}</div>
					<h3 class="mb-2.5 text-[22px] font-bold leading-[1.15] tracking-[-0.02em]">{f.lyrics.title}</h3>
					<p class="text-[14.5px] text-text-2 text-pretty">{f.lyrics.desc}</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ─────────────  Showcase scroll  ───────────── -->
	<section id="showcase" class="overflow-hidden pb-35 pt-20">
		<div class="mx-auto mb-20 grid max-w-[1280px] grid-cols-1 items-end gap-x-15 gap-y-6 px-8 lg:grid-cols-2">
			<h2 class="text-[clamp(40px,5.5vw,76px)] font-extrabold leading-[1.02] tracking-[-0.04em] text-balance">
				{t.showcase.headingPre} <em class="font-extrabold italic text-accent pr-[0.12em]">{t.showcase.headingEm}</em>
			</h2>
			<p class="self-end text-lg text-text-2 text-pretty">{t.showcase.sub}</p>
		</div>
		<div id="showcase-track" class="showcase-track flex w-max gap-7 cursor-grab touch-pan-y select-none will-change-transform">
			{
				[...showcase, ...showcase].map((shot) => (
					<div class="w-[280px] shrink-0 overflow-hidden rounded-[32px] border border-border-strong bg-black shadow-[0_30px_60px_-20px_rgba(0,0,0,0.6)] pointer-events-none">
						<Image src={shot} alt="" class="block w-full" draggable={false} />
					</div>
				))
			}
		</div>
	</section>

	<script>
		const track = document.getElementById('showcase-track');
		if (track) {
			const SPEED = 50; // px/sec
			let halfWidth = 0;
			const measure = () => {
				halfWidth = track.scrollWidth / 2;
			};
			measure();
			window.addEventListener('resize', measure);
			if ('fonts' in document) document.fonts.ready.then(measure);

			let offset = 0;
			let paused = false;
			let hovered = false;
			let dragging = false;
			let dragStartX = 0;
			let dragStartOffset = 0;
			let lastT = performance.now();
			let velocity = 0; // px/sec, carries momentum after release
			let lastPointerX = 0;
			let lastPointerT = 0;

			const wrap = (v: number) => {
				if (halfWidth <= 0) return v;
				while (v <= -halfWidth) v += halfWidth;
				while (v > 0) v -= halfWidth;
				return v;
			};

			const apply = () => {
				track.style.transform = `translate3d(${offset}px, 0, 0)`;
			};

			const tick = (t: number) => {
				const dt = (t - lastT) / 1000;
				lastT = t;
				if (!dragging) {
					if (Math.abs(velocity) > 0.5) {
						// momentum: decay toward the base scroll speed
						offset = wrap(offset + velocity * dt);
						velocity *= Math.pow(0.001, dt); // ~exponential decay, ~halves every ~70ms
						apply();
					} else if (!paused && !hovered) {
						velocity = 0;
						offset = wrap(offset - SPEED * dt);
						apply();
					}
				}
				requestAnimationFrame(tick);
			};
			requestAnimationFrame((t) => { lastT = t; tick(t); });

			track.addEventListener('mouseenter', () => { hovered = true; });
			track.addEventListener('mouseleave', () => { hovered = false; });

			track.addEventListener('pointerdown', (e) => {
				dragging = true;
				velocity = 0;
				dragStartX = e.clientX;
				dragStartOffset = offset;
				lastPointerX = e.clientX;
				lastPointerT = performance.now();
				track.setPointerCapture(e.pointerId);
				track.style.cursor = 'grabbing';
			});
			track.addEventListener('pointermove', (e) => {
				if (!dragging) return;
				const now = performance.now();
				const dt = (now - lastPointerT) / 1000;
				if (dt > 0) {
					// low-pass filter so a single jittery sample doesn't dominate
					const instantV = (e.clientX - lastPointerX) / dt;
					velocity = velocity * 0.6 + instantV * 0.4;
				}
				lastPointerX = e.clientX;
				lastPointerT = now;
				offset = wrap(dragStartOffset + (e.clientX - dragStartX));
				apply();
			});
			const endDrag = (e: PointerEvent) => {
				if (!dragging) return;
				dragging = false;
				// clamp so a tiny flick doesn't fling forever
				const MAX_V = 4000;
				if (velocity > MAX_V) velocity = MAX_V;
				if (velocity < -MAX_V) velocity = -MAX_V;
				try { track.releasePointerCapture(e.pointerId); } catch {}
				track.style.cursor = 'grab';
			};
			track.addEventListener('pointerup', endDrag);
			track.addEventListener('pointercancel', endDrag);
		}
	</script>

