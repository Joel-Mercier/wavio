---
import Logo from "../assets/logo.svg";
import { GITHUB_URL } from "../consts";
import {
  defaultLang,
  type Lang,
  languages,
  localizePath,
  stripLangFromPath,
  useTranslations,
} from "../i18n/utils";

interface Props {
  lang: Lang;
  /** Show the Features / GitHub links (homepage only) */
  showLinks?: boolean;
}

const { lang, showLinks = false } = Astro.props;
const t = useTranslations(lang);
const home = localizePath("/", lang);

// Build language-switcher targets that keep the visitor on the current page.
const basePath = stripLangFromPath(Astro.url.pathname);
const langLinks = (Object.keys(languages) as Lang[]).map((code) => ({
  code,
  href: localizePath(basePath, code),
  current: code === lang,
}));
---

<nav class="sticky top-0 z-50 border-b border-white/5 bg-bg/65 backdrop-blur-xl">
	<div class="mx-auto flex h-[72px] max-w-[1280px] items-center justify-between px-8">
		<a href={home} class="flex items-center gap-3 text-[19px] font-extrabold tracking-[-0.02em] text-text">
			<Logo width={30} height={30} aria-hidden="true" />
			Wavio
		</a>
		<div class="flex items-center gap-6 text-sm text-text-2 sm:gap-9">
			{
				showLinks && (
					<>
						<a href={`${home}#features`} class="hidden transition-colors hover:text-text md:inline">{t.nav.features}</a>
						<a href={GITHUB_URL} target="_blank" rel="noopener" class="hidden transition-colors hover:text-text md:inline">{t.nav.github}</a>
					</>
				)
			}
			<div class="flex items-center gap-1 text-[13px] font-semibold" aria-label="Language">
				{
					langLinks.map((l, i) => (
						<>
							{i > 0 && <span class="text-text-3">/</span>}
							<a
								href={l.href}
								hreflang={l.code}
								aria-current={l.current ? 'true' : undefined}
								class:list={[
									'uppercase transition-colors hover:text-text',
									l.current ? 'text-accent' : 'text-text-3',
								]}
							>{l.code}</a>
						</>
					))
				}
			</div>
			<a
				href={`${home}#download`}
				class="rounded-full bg-accent px-5 py-2.5 text-[13px] font-bold text-ink transition-all duration-150 hover:-translate-y-px hover:shadow-[0_8px_24px_-6px_rgba(16,185,129,0.35)]"
			>{t.nav.download}</a>
		</div>
	</div>
</nav>
