---
import Logo from "../assets/logo.svg";
import { GITHUB_URL } from "../consts";
import {
  defaultLang,
  type Lang,
  languages,
  localizePath,
  stripLangFromPath,
  useTranslations,
} from "../i18n/utils";

interface Props {
  lang: Lang;
  /** Show the Features / GitHub links (homepage only) */
  showLinks?: boolean;
}

const { lang, showLinks = false } = Astro.props;
const t = useTranslations(lang);
const home = localizePath("/", lang);

// Build language-switcher targets that keep the visitor on the current page.
const basePath = stripLangFromPath(Astro.url.pathname);
const langLinks = (Object.keys(languages) as Lang[]).map((code) => ({
  code,
  href: localizePath(basePath, code),
  current: code === lang,
}));
---

<nav class="sticky top-0 z-50 border-b border-white/5 bg-bg/65 backdrop-blur-xl">
	<div class="mx-auto flex h-[72px] max-w-[1280px] items-center justify-between px-8">
		<a href={home} class="flex items-center gap-3 text-[19px] font-extrabold tracking-[-0.02em] text-text">
			<Logo width={30} height={30} aria-hidden="true" />
			Wavio
		</a>
		<div class="flex items-center gap-6 text-sm text-text-2 sm:gap-9">
			{
				showLinks && (
					<>
						<a href={`${home}#features`} class="hidden transition-colors hover:text-text md:inline">{t.nav.features}</a>
						<a href={GITHUB_URL} target="_blank" rel="noopener" class="hidden transition-colors hover:text-text md:inline">{t.nav.github}</a>
					</>
				)
			}
			<details class="lang-switcher group relative text-[13px] font-semibold">
				<summary
					class="flex cursor-pointer list-none items-center gap-1.5 text-text-2 transition-colors hover:text-text [&::-webkit-details-marker]:hidden"
					aria-label="Language"
				>
					{languages[lang]}
					<svg
						width="12"
						height="12"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2.5"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
						class="transition-transform duration-150 group-open:rotate-180"
					>
						<path d="m6 9 6 6 6-6" />
					</svg>
				</summary>
				<ul class="absolute right-0 top-full mt-2 min-w-[140px] overflow-hidden rounded-xl border border-white/10 bg-bg/95 py-1 shadow-[0_12px_32px_-8px_rgba(0,0,0,0.5)] backdrop-blur-xl">
					{
						langLinks.map((l) => (
							<li>
								<a
									href={l.href}
									hreflang={l.code}
									aria-current={l.current ? 'true' : undefined}
									class:list={[
										'block px-4 py-2 transition-colors hover:bg-white/5 hover:text-text',
										l.current ? 'text-accent' : 'text-text-2',
									]}
								>{languages[l.code]}</a>
							</li>
						))
					}
				</ul>
			</details>
			<a
				href={`${home}#download`}
				class="rounded-full bg-accent px-5 py-2.5 text-[13px] font-bold text-ink transition-all duration-150 hover:-translate-y-px hover:shadow-[0_8px_24px_-6px_rgba(16,185,129,0.35)]"
			>{t.nav.download}</a>
		</div>
	</div>
</nav>

<script>
	document.addEventListener('click', (e) => {
		for (const details of document.querySelectorAll<HTMLDetailsElement>('details.lang-switcher[open]')) {
			if (!details.contains(e.target as Node)) details.removeAttribute('open');
		}
	});
</script>
