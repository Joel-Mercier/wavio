	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@types/jest": "29.5.14",
		"@types/node": "^22.19.21",
		"@types/react": "~19.2.17",
		"@types/react-test-renderer": "^19.1.0",
		"expo-atlas": "^0.4.0",
		"jest": "~29.7.0",
		"jest-expo": "~56.0.5",
		"jscodeshift": "^17.3.0",
		"react-native-svg-transformer": "^1.5.3",
		"react-test-renderer": "19.2.7",
		"tailwindcss": "^4.3.1",
		"typescript": "~6.0.3"
	},
	"private": true,
	"expo": {
		"autolinking": {
			"android": {
				"buildFromSource": [
					"expo-audio"
				]
			}
		},
		"install": {
			"exclude": [
				"@shopify/flash-list"
			]
		}
	}
}
