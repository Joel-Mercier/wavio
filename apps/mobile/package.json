{
	"name": "wavio",
	"main": "index.js",
	"version": "1.0.4",
	"license": "MIT",
	"scripts": {
		"start": "eas env:exec --non-interactive development \"expo start\"",
		"prebuild": "bunx expo prebuild",
		"doctor": "bunx expo-doctor",
		"reset-project": "bun ./scripts/reset-project.js",
		"android": "eas env:exec --non-interactive development \"DARK_MODE=media expo run:android\"",
		"ios": "eas env:exec --non-interactive development \"DARK_MODE=media expo run:ios\"",
		"web": "eas env:exec --non-interactive development \"DARK_MODE=media expo start --web\"",
		"test": "bunx jest",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"typecheck": "bunx tsc --noEmit",
		"build:android:development": "eas build -p android --profile development --local",
		"build:android:preview": "eas build -p android --profile preview --local",
		"build:android:production": "eas build -p android --profile production --local",
		"build:android:production-apk": "eas build -p android --profile production-apk --local",
		"submit:android:closed": "eas submit -p android --profile closed",
		"submit:android:production": "eas submit -p android --profile production"
	},
	"jest": {
		"preset": "jest-expo",
		"transformIgnorePatterns": [
			"/node_modules/(?!(.pnpm|react-native|@react-native|@react-native-community|expo|@expo|@expo-google-fonts|react-navigation|@react-navigation|@sentry|native-base|standard-navigation))",
			"/node_modules/react-native-reanimated/plugin/",
			"/node_modules/@react-native/babel-preset/"
		]
	},
	"dependencies": {
		"@expo-google-fonts/inter": "^0.4.2",
		"@expo/html-elements": "^56.0.1",
		"@expo/metro-runtime": "~56.0.15",
		"@gluestack-ui/core": "^5.0.14-alpha.0",
		"@gluestack-ui/utils": "^5.0.6-alpha.0",
		"@gorhom/bottom-sheet": "^5.2.13",
		"@legendapp/motion": "^2.5.3",
		"@react-native-community/datetimepicker": "9.1.0",
		"@react-native-community/netinfo": "^12.0.1",
		"@sentry/react-native": "^8.15.0",
		"@shopify/flash-list": "^2.3.2",
		"@tanstack/query-async-storage-persister": "^5.101.0",
		"@tanstack/react-form": "^1.33.0",
		"@tanstack/react-query": "^5.101.0",
		"@tanstack/react-query-persist-client": "^5.101.0",
		"axios": "^1.18.0",
		"babel-plugin-module-resolver": "^5.0.3",
		"clsx": "^2.1.1",
		"date-fns": "^4.4.0",
		"expo": "^56.0.12",
		"expo-application": "~56.0.3",
		"expo-asset": "~56.0.17",
		"expo-audio": "56.0.12",
		"expo-build-properties": "~56.0.19",
		"expo-clipboard": "~56.0.4",
