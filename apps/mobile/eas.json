{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "env": {
        "EXPO_PUBLIC_OPENSUBSONIC_API_VERSION": "1.16.1",
        "EXPO_PUBLIC_CLIENT_NAME": "wavio",
        "EXPO_PUBLIC_ENV": "development",
        "EXPO_PUBLIC_DISTRIBUTION": "github"
      }
    },
    "preview": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=arm64-v8a"
      },
      "distribution": "internal",
      "environment": "preview",
      "env": {
        "EXPO_PUBLIC_OPENSUBSONIC_API_VERSION": "1.16.1",
        "EXPO_PUBLIC_CLIENT_NAME": "wavio",
        "EXPO_PUBLIC_ENV": "preview",
        "EXPO_PUBLIC_DISTRIBUTION": "github"
      }
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_OPENSUBSONIC_API_VERSION": "1.16.1",
        "EXPO_PUBLIC_CLIENT_NAME": "wavio",
        "EXPO_PUBLIC_ENV": "production",
        "EXPO_PUBLIC_DISTRIBUTION": "store"
      }
    },
    "production-apk": {
      "extends": "production",
      "autoIncrement": false,
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=arm64-v8a"
      },
      "env": {
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "EXPO_PUBLIC_DISTRIBUTION": "github"
      }
    },
    "production-apk-armv7": {
      "extends": "production-apk",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=armeabi-v7a"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "production"
      }
    },
    "closed": {
      "android": {
        "track": "alpha"
      }
    }
  }
}
